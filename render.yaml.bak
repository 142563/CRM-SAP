services:
  - type: web
    name: crm-erp-umg
    runtime: docker
    dockerfilePath: ./Dockerfile
    envVars:
      - key: ASPNETCORE_ENVIRONMENT
        value: Production
      - key: DATABASE_URL
        fromDatabase:
          name: crm-erp-db
          property: connectionString

databases:
  - name: crm-erp-db
    plan: free
    databaseName: crm_erp_umg
    user: crm_user
