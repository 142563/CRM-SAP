@model IEnumerable<CRM_ERP_UMG.Models.ModuloDinamico>
@{ ViewData["Title"] = "Módulos Dinámicos"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-boxes me-2"></i>Módulos Dinámicos</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
    {
        <a asp-action="Crear" class="btn btn-dark">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Módulo
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay módulos registrados.</div>
}
else
{
    <div class="row g-3">
        @foreach (var modulo in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@modulo.NombreModulo</h5>
                        <p class="card-text text-muted small">@modulo.Descripcion</p>
                        <div class="d-flex gap-2 text-muted small mb-3">
                            <span><i class="bi bi-table me-1"></i>@modulo.EsquemaCampos.Count campos</span>
                            <span><i class="bi bi-file-earmark-text me-1"></i>@modulo.Registros.Count registros</span>
                            <span><i class="bi bi-calculator me-1"></i>@modulo.Operaciones.Count operaciones</span>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="Detalle" asp-route-id="@modulo.Id" class="btn btn-outline-dark btn-sm">
                                <i class="bi bi-gear me-1"></i>Configurar
                            </a>
                            <a asp-controller="Registros" asp-action="Index" asp-route-moduloId="@modulo.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-table me-1"></i>Registros
                            </a>
                            <a asp-controller="Operaciones" asp-action="Index" asp-route-moduloId="@modulo.Id" class="btn btn-outline-success btn-sm">
                                <i class="bi bi-calculator me-1"></i>Operaciones
                            </a>
                        </div>
                    </div>
                    <div class="card-footer text-muted small">
                        Creado: @modulo.FechaCreacion.ToString("dd/MM/yyyy")
                    </div>
                </div>
            </div>
        }
    </div>
}
