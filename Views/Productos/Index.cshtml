@model IEnumerable<CRM_ERP_UMG.Models.Producto>
@{ ViewData["Title"] = "Productos"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam me-2"></i>Productos</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
    {
        <a asp-action="Crear" class="btn btn-dark">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Producto
        </a>
    }
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Código</th><th>Nombre</th><th>Descripción</th>
                    <th class="text-end">Precio</th><th class="text-end">Existencia</th>
                    <th>Estado</th>
                    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                    {
                        <th>Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><code>@p.Codigo</code></td>
                        <td>@p.Nombre</td>
                        <td class="text-muted small">@p.Descripcion</td>
                        <td class="text-end">Q @p.PrecioVenta.ToString("F2")</td>
                        <td class="text-end">@p.Existencia.ToString("F0")</td>
                        <td>
                            <span class="badge @(p.Activo ? "bg-success" : "bg-secondary")">
                                @(p.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                        {
                            <td>
                                <a asp-action="Editar" asp-route-id="@p.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
