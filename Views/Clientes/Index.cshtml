@model IEnumerable<CRM_ERP_UMG.Models.Cliente>
@{ ViewData["Title"] = "Clientes"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people me-2"></i>Clientes</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Editor") || User.IsInRole("Vendedor"))
    {
        <a asp-action="Crear" class="btn btn-dark">
            <i class="bi bi-person-plus me-1"></i>Nuevo Cliente
        </a>
    }
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>NIT</th><th>Nombre</th><th>Teléfono</th><th>Dirección</th><th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Nit</td>
                        <td>@c.Nombre</td>
                        <td>@c.Telefono</td>
                        <td class="text-muted small">@c.Direccion</td>
                        <td>
                            <span class="badge @(c.Activo ? "bg-success" : "bg-secondary")">
                                @(c.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
