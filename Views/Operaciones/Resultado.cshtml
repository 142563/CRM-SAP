@model IEnumerable<Dictionary<string, string>>
@{
    ViewData["Title"] = "Resultado";
    var operacion = ViewBag.Operacion as CRM_ERP_UMG.Models.OperacionDinamica;
    var columnas = operacion?.ColumnasVisibles ?? new List<string>();
    var formulas = operacion?.Formulas ?? new List<CRM_ERP_UMG.Models.FormulaDinamica>();
    var todas = columnas.Concat(formulas.Select(f => f.NombreResultado)).ToList();
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Index" asp-route-moduloId="@operacion?.ModuloDinamicoId" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="mb-0">@operacion?.NombreOperacion</h2>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay registros para procesar.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        @foreach (var col in columnas)
                        {
                            <th>@col</th>
                        }
                        @foreach (var f in formulas)
                        {
                            <th class="text-warning">@f.NombreResultado</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fila in Model)
                    {
                        <tr>
                            @foreach (var col in todas)
                            {
                                <td>@(fila.TryGetValue(col, out var v) ? v : "")</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
