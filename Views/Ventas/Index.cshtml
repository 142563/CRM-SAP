@model IEnumerable<CRM_ERP_UMG.Models.Venta>
@{ ViewData["Title"] = "Ventas"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-receipt me-2"></i>Ventas</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Editor") || User.IsInRole("Vendedor"))
    {
        <a asp-action="Crear" class="btn btn-dark">
            <i class="bi bi-plus-lg me-1"></i>Nueva Venta
        </a>
    }
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>N° Venta</th><th>Cliente</th><th>Vendedor</th>
                    <th class="text-end">Total</th><th>Estado</th><th>Fecha</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    <tr>
                        <td><code>@v.NumeroVenta</code></td>
                        <td>@v.Cliente?.Nombre</td>
                        <td class="small text-muted">@v.Usuario?.NombreCompleto</td>
                        <td class="text-end fw-semibold">Q @v.Total.ToString("F2")</td>
                        <td><span class="badge bg-success">@v.Estado</span></td>
                        <td class="small text-muted">@v.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <a asp-action="Detalle" asp-route-id="@v.Id" class="btn btn-outline-dark btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
