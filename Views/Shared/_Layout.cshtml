<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRM ERP UMG</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { min-height: 100vh; background-color: #212529; position: relative; }
        .sidebar .nav-link { color: #adb5bd; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background-color: #343a40; border-radius: 4px; }
        .nav-section { color: #6c757d; font-size: 0.75rem; text-transform: uppercase; padding: 0.5rem 1rem; }
    </style>
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="container-fluid">
            <div class="row">
                <nav class="col-md-2 d-none d-md-block sidebar p-0">
                    <div class="p-3 text-white fw-bold border-bottom border-secondary">
                        <i class="bi bi-grid-3x3-gap-fill me-2"></i>CRM ERP UMG
                    </div>
                    <ul class="nav flex-column py-2 px-2">
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2" asp-controller="Modulos" asp-action="Index">
                                <i class="bi bi-boxes me-2"></i>Módulos Dinámicos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2" asp-controller="Clientes" asp-action="Index">
                                <i class="bi bi-people me-2"></i>Clientes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2" asp-controller="Productos" asp-action="Index">
                                <i class="bi bi-box-seam me-2"></i>Productos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2" asp-controller="Ventas" asp-action="Index">
                                <i class="bi bi-receipt me-2"></i>Ventas
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item mt-2">
                                <span class="nav-section">Administración</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2" asp-controller="Usuarios" asp-action="Index">
                                    <i class="bi bi-person-gear me-2"></i>Usuarios
                                </a>
                            </li>
                        }
                    </ul>
                    <div class="p-3 border-top border-secondary mt-3">
                        <span class="text-muted small d-block mb-2 text-truncate">@User.Identity?.Name</span>
                        <form asp-controller="Cuenta" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                <i class="bi bi-box-arrow-right me-1"></i>Salir
                            </button>
                        </form>
                    </div>
                </nav>
                <main class="col-md-10 ms-sm-auto p-4">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <div class="container">
            @RenderBody()
        </div>
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
