@model IEnumerable<CRM_ERP_UMG.Models.UsuarioListadoVista>
@{ ViewData["Title"] = "Usuarios"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-gear me-2"></i>Usuarios del Sistema</h2>
    <a asp-action="Crear" class="btn btn-dark">
        <i class="bi bi-person-plus me-1"></i>Nuevo Usuario
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th><th>Email</th><th>Roles</th><th>Cambiar Rol</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.NombreCompleto</td>
                        <td>@u.Email</td>
                        <td>
                            @foreach (var rol in u.Roles)
                            {
                                <span class="badge bg-dark me-1">@rol</span>
                            }
                        </td>
                        <td>
                            <form asp-action="CambiarRol" method="post" class="d-flex gap-2">
                                <input type="hidden" name="userId" value="@u.Id" />
                                <select name="nuevoRol" class="form-select form-select-sm" style="width:auto">
                                    <option value="Admin">Admin</option>
                                    <option value="Editor">Editor</option>
                                    <option value="Viewer">Viewer</option>
                                    <option value="Vendedor">Vendedor</option>
                                </select>
                                <button type="submit" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
